# Copy to .env and fill in.
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Rolling tokens-per-minute budget for Groq free tier (leave headroom under 6000).
GROQ_TPM_BUDGET=5000

# Circuit breaker: consecutive LLM failures before we stop calling and fall back to ask_user.
LLM_FAILURE_THRESHOLD=3

# Path to your resume PDF (used by seed_profile). Optional in Phase 1.
RESUME_PDF_PATH=

# Optional: free Telegram push notifications for handoff pings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
