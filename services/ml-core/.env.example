# Career OS Backend Configuration
# Copy this file to .env and fill in your values

# LLM Provider API Key (users MUST bring their own key)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Rolling tokens-per-minute budget for Groq free tier (leave headroom under 6000).
GROQ_TPM_BUDGET=5000

# Path to your resume PDF (used for auto-upload and profile extraction)
RESUME_PDF_PATH=C:\path\to\your\resume.pdf

# Behavior: pause for confirmation before final submit? (true/false)
REVIEW_BEFORE_SUBMIT=false

# Optional: Telegram notifications when an application is submitted
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
